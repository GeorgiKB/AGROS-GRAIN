{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/en",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/en/:path*",
      "destination": "/:path*",
      "permanent": true
    },
    {
      "source": "/bg/%D0%BA%D0%BE%D0%BD%D1%82%D0%B0%D0%BA%D1%82%D0%B8",
      "destination": "/bg/contact",
      "permanent": true
    },
    {
      "source": "/bg/контакти",
      "destination": "/bg/contact",
      "permanent": true
    },
    {
      "source": "/flaxseed-golden",
      "destination": "/flaxseed-yellow",
      "permanent": true
    },
    {
      "source": "/bg/flaxseed-golden",
      "destination": "/bg/flaxseed-yellow",
      "permanent": true
    },
    {
      "source": "/de/flaxseed-golden",
      "destination": "/de/flaxseed-yellow",
      "permanent": true
    }
  ]
}
